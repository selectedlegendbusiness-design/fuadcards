{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "User profile and game stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "integer" },
        "favAnime": { "type": "string" },
        "totalPower": { "type": "integer" },
        "lastGenerations": { 
          "type": "array",
          "items": { "type": "string", "format": "date-time" },
          "description": "Timestamps of the last 2 card generations"
        },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "name", "totalPower", "role"]
    },
    "Card": {
      "title": "Card",
      "description": "Collectible anime trading card",
      "type": "object",
      "properties": {
        "cardId": { "type": "string" },
        "player_id": { "type": "string" },
        "ownerName": { "type": "string" },
        "characterName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "raw_power": { "type": "integer" },
        "strength": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "ordered", "approved"] },
        "is_approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "accentColor": { "type": "string" },
        "prompt_text": { "type": "string" },
        "qr_data": { "type": "string" }
      },
      "required": ["cardId", "player_id", "imageUrl", "raw_power", "strength"]
    }
  },
  "firestore": {
    "/players/{uid}": {
      "schema": "Player",
      "description": "Player profiles"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Generated cards"
    }
  }
}
