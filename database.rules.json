{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "cards": {
      "$cardId": {
        ".read": "true",
        ".write": "auth != null && (!data.exists() || data.child('player_id').val() === auth.uid)"
      }
    },
    "players": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
